{
  "name": "file-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/backend",
    "build": "npm run build --workspaces",
    "test": "vitest run",
    "clean": "npm run clean --workspaces --if-present"
  },
  "devDependencies": {
    "vitest": "^4.1.2"
  }
}
